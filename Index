      (function() {
        window.dataLayer = window.dataLayer || [];
        if (typeof window.trackFunnelEvent !== 'function') {
          window.trackFunnelEvent = function(eventName, params) {
            try {
              window.dataLayer.push(Object.assign({ event: eventName }, params || {}));
            } catch (_e) {}
          };
        }
      })();
    </script>
